{
  "name": "@nexus-state/react",
  "version": "0.1.8",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js",
      "require": "./dist/context.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist && mkdir dist",
    "dev": "tsc -w",
    "test": "vitest run index.test.ts",
    "test:coverage": "vitest run index.test.ts --coverage",
    "lint": "eslint . --ext .ts"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^8.40.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.7",
    "jsdom": "^26.1.0"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  }
}