{
    "globalDependencies": ["**/.env.*local"],
    "globalEnv": ["CI", "NODE_ENV"],
    "pipeline": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ],
            "env": ["NODE_ENV"]
        },
        "dev": {
            "cache": false
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "test:coverage": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "coverage/**"
            ]
        },
        "lint": {}
    }
}