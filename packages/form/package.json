{
  "name": "@nexus-state/form",
  "version": "0.1.0",
  "description": "Type-safe form management with field-level granularity for Nexus State",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "state-management",
    "forms",
    "validation",
    "nexus-state",
    "typescript"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.0.0",
    "yup": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7",
    "eslint": "^8.57.1",
    "zod": "^3.23.8",
    "yup": "^1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eustatos/nexus-state",
    "directory": "packages/form"
  },
  "homepage": "https://nexus-state.website.yandexcloud.net/",
  "license": "MIT",
  "author": "Nexus State Contributors"
}
