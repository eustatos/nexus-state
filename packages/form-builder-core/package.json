{
  "name": "@nexus-state/form-builder-core",
  "version": "0.1.1",
  "description": "Core logic for Nexus State Form Builder (framework-agnostic)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js",
      "require": "./dist/registry.cjs"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js",
      "require": "./dist/state.cjs"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js",
      "require": "./dist/export.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "size": "size-limit"
  },
  "keywords": [
    "form-builder",
    "drag-and-drop",
    "visual-builder",
    "nexus-state",
    "forms",
    "no-code",
    "core"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*",
    "@nexus-state/form": "workspace:*"
  },
  "peerDependencies": {},
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "@types/node": "^20.0.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eustatos/nexus-state",
    "directory": "packages/form-builder-core"
  },
  "license": "MIT",
  "author": "Nexus State Contributors"
}