{
  "name": "nexus-state",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:packages": "pnpm --filter \"@nexus-state/*\" test:coverage",
    "test:memory": "vitest run packages/core/src/__tests__/memory-leak.test.ts",
    "bench": "vitest bench packages/core/src/__benchmarks__/",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:ci": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "format": "prettier --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:serve": "vitepress serve docs",
    "coverage:badges": "node scripts/add-coverage-badges.js",
    "coverage:badge": "node scripts/add-coverage-badges.js",
    "test:e2e": "npm run test --workspace=e2e",
    "dev:react": "npm run dev --workspace=demo-react",
    "dev:svelte": "npm run dev --workspace=demo-svelte",
    "dev:vanilla": "npm run dev --workspace=demo-vanilla",
    "dev:vue": "npm run dev --workspace=demo-vue",
    "dev:async": "npm run dev --workspace=demo-async",
    "dev:family": "npm run dev --workspace=demo-family",
    "dev:immer": "npm run dev --workspace=demo-immer",
    "dev:middleware": "npm run dev --workspace=demo-middleware",
    "dev:persist": "npm run dev --workspace=demo-persist",
    "dev:forms": "npm run dev --workspace=demo-forms-granularity",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run release:packages && changeset publish",
    "release:packages": "turbo run build --filter=@nexus-state/*",
    "coverage:merge": "mkdir -p coverage && find packages -name \"lcov.info\" -exec cat {} \\; > coverage/lcov.info 2>/dev/null || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.0.7",
    "ajv": "^8.18.0",
    "commander": "^11.0.0",
    "eslint": "^10.0.2",
    "fs-extra": "^11.0.0",
    "globals": "^17.3.0",
    "immer": "^10.0.0",
    "jscpd": "^4.0.8",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.7"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^10.2.3",
      "basic-ftp": "^5.2.0",
      "rollup": "^4.59.0",
      "esbuild": "^0.25.0",
      "vite": "^5.4.21",
      "svelte": "^5.53.5",
      "ajv": "^6.14.0",
      "@types/node": "^20.0.0"
    }
  }
}
