{
  "name": "@nexus-state/form-builder-ui",
  "version": "0.2.0",
  "description": "React UI components for Nexus State Form Builder with drag-and-drop",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "require": "./dist/styles.css"
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "size": "size-limit"
  },
  "keywords": [
    "form-builder",
    "react",
    "drag-and-drop",
    "dnd",
    "nexus-state",
    "ui",
    "components"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*",
    "@nexus-state/form": "workspace:*",
    "@nexus-state/form-builder-core": "workspace:*",
    "@nexus-state/form-builder-react": "workspace:*",
    "@nexus-state/react": "workspace:*",
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^7.0.0",
    "@dnd-kit/utilities": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eustatos/nexus-state",
    "directory": "packages/form-builder-ui"
  },
  "license": "MIT",
  "author": "Nexus State Contributors"
}