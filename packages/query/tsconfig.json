{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "esModuleInterop": true
  },
  "include": ["src/**/*", "react/**/*"],
  "exclude": ["src/**/*.test.ts", "react/**/*.test.tsx", "node_modules", "dist"]
}
