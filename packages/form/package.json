{
  "name": "@nexus-state/form",
  "version": "0.1.2",
  "description": "Type-safe form management with field-level granularity for Nexus State",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "require": "./dist/validation.js"
    },
    "./submission": {
      "types": "./dist/submission.d.ts",
      "import": "./dist/submission.js",
      "require": "./dist/submission.js"
    },
    "./field-array": {
      "types": "./dist/field-array.d.ts",
      "import": "./dist/field-array.js",
      "require": "./dist/field-array.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "state-management",
    "forms",
    "validation",
    "nexus-state",
    "typescript",
    "react"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*",
    "@nexus-state/react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "zod": "^3.0.0",
    "yup": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@vitest/coverage-v8": "^3.0.7",
    "typescript": "^5.9.3",
    "vitest": "^3.0.7",
    "eslint": "^8.57.1",
    "zod": "^3.23.8",
    "yup": "^1.4.0",
    "react": "^18.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eustatos/nexus-state",
    "directory": "packages/form"
  },
  "homepage": "https://nexus-state.website.yandexcloud.net/",
  "license": "MIT",
  "author": "Nexus State Contributors"
}