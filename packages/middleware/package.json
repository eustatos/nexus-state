{
  "name": "@nexus-state/middleware",
  "version": "1.0.1",
  "description": "Middleware plugin for Nexus State with plugin hooks support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "MIGRATION.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "vitest run src",
    "test:coverage": "vitest run src --coverage",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@nexus-state/core": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.7",
    "typescript": "^5.0.0",
    "vitest": "^3.0.7",
    "eslint": "^8.40.0"
  },
  "keywords": [
    "nexus-state",
    "middleware",
    "plugin",
    "hooks",
    "state-management",
    "reactive"
  ],
  "author": "Nexus State Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eustatos/nexus-state.git",
    "directory": "packages/middleware"
  },
  "homepage": "https://nexus-state.website.yandexcloud.net/",
  "bugs": {
    "url": "https://github.com/eustatos/nexus-state/issues"
  }
}