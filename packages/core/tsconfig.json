{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/esm",
    "rootDir": "src",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "target": "ES2019",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "downlevelIteration": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test-d.ts",
    "src/**/*.backup.ts",
    "node_modules",
    "dist"
  ]
}
