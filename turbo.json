{
    "globalDependencies": ["**/.env.*local"],
    "globalEnv": ["CI", "NODE_ENV"],
    "pipeline": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ],
            "env": ["NODE_ENV"]
        },
        "dev": {
            "cache": false
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [],
            "timeout": 600
        },
        "test:coverage": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "coverage/**"
            ],
            "timeout": 900
        },
        "lint": {
            "timeout": 300
        }
    }
}