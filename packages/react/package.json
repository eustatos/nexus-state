{
  "name": "@nexus-state/react",
  "version": "0.1.14",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./context": {
      "types": "./dist/esm/context.d.ts",
      "import": "./dist/esm/context.js",
      "require": "./dist/cjs/context.js"
    }
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist && mkdir dist",
    "dev": "tsc -w",
    "test": "vitest run index.test.ts",
    "test:coverage": "vitest run index.test.ts --coverage",
    "lint": "eslint . --ext .ts"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@nexus-state/core": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/react": "^12.0.0 || ^14.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^17.0.0",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^8.40.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.7",
    "jsdom": "^26.1.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0 <20.0.0"
  }
}